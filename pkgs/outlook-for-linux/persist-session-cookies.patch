+fn should_save_cookies_for_url(url: &Url) -> bool {
+    url.host_str()
+        .map(is_microsoft_cookie_host)
+        .unwrap_or(false)
+}
+
+fn is_microsoft_cookie_host(host: &str) -> bool {
+    let host = host.trim_start_matches('.').to_ascii_lowercase();
+    MICROSOFT_COOKIE_HOST_SUFFIXES
+        .iter()
+        .any(|suffix| host == *suffix || host.ends_with(&format!(".{}", suffix)))
+}
+
+fn session_cookie_path(app: &AppHandle) -> Result<PathBuf, Box<dyn std::error::Error>> {
+    let dir = app.path().app_data_dir()?;
+    fs::create_dir_all(&dir)?;
+    Ok(dir.join(SESSION_COOKIE_FILE))
+}
+
+fn is_session_cookie(cookie: &Cookie<'_>) -> bool {
+    cookie.expires_datetime().is_none() && cookie.max_age().is_none()
+}
+
+fn stored_session_cookie(cookie: &Cookie<'_>) -> Option<StoredSessionCookie> {
+    if !is_session_cookie(cookie) {
+        return None;
+    }
+
+    if let Some(domain) = cookie.domain() {
+        if !is_microsoft_cookie_host(domain) {
+            return None;
+        }
+    }
+
+    Some(StoredSessionCookie {
+        name: cookie.name().to_string(),
+        value: cookie.value().to_string(),
+        domain: cookie.domain().map(ToString::to_string),
+        path: cookie.path().map(ToString::to_string),
+        secure: cookie.secure(),
+        http_only: cookie.http_only(),
+        same_site: cookie.same_site().map(|same_site| format!("{:?}", same_site)),
+    })
+}
+
+fn save_session_cookies(window: &WebviewWindow) -> Result<(), Box<dyn std::error::Error>> {
+    let cookies: Vec<_> = window
+        .cookies()?
+        .into_iter()
+        .filter_map(|cookie| stored_session_cookie(&cookie))
+        .collect();
+    let data = serde_json::to_vec_pretty(&cookies)?;
+    let path = session_cookie_path(window.app_handle())?;
+
+    let mut options = OpenOptions::new();
+    options.create(true).truncate(true).write(true);
+    #[cfg(unix)]
+    options.mode(0o600);
+
+    let mut file = options.open(path)?;
+    file.write_all(&data)?;
+    Ok(())
+}
+
+fn restore_session_cookies(window: &WebviewWindow) -> Result<(), Box<dyn std::error::Error>> {
+    let path = session_cookie_path(window.app_handle())?;
+    if !path.exists() {
+        return Ok(());
+    }
+
+    let data = fs::read(path)?;
+    let cookies: Vec<StoredSessionCookie> = serde_json::from_slice(&data)?;
+    for cookie in cookies {
+        if let Some(domain) = &cookie.domain {
+            if !is_microsoft_cookie_host(domain) {
+                continue;
+            }
+        }
+
+        match cookie.to_cookie() {
+            Ok(cookie) => {
+                if let Err(err) = window.set_cookie(cookie) {
+                    eprintln!("failed to restore session cookie: {}", err);
+                }
+            }
+            Err(err) => eprintln!("failed to parse stored session cookie: {}", err),
+        }
+    }
+
+    Ok(())
+}
+
+impl StoredSessionCookie {
+    fn to_cookie(&self) -> Result<Cookie<'static>, Box<dyn std::error::Error>> {
+        let mut cookie = format!("{}={}", self.name, self.value);
+        if let Some(domain) = &self.domain {
+            cookie.push_str(&format!("; Domain={}", domain));
+        }
+        if let Some(path) = &self.path {
+            cookie.push_str(&format!("; Path={}", path));
+        }
+        if self.secure.unwrap_or(false) {
+            cookie.push_str("; Secure");
+        }
+        if self.http_only.unwrap_or(false) {
+            cookie.push_str("; HttpOnly");
+        }
+        if let Some(same_site) = &self.same_site {
+            cookie.push_str(&format!("; SameSite={}", same_site));
+        }
+        Ok(Cookie::parse(cookie)?)
+    }
+}
