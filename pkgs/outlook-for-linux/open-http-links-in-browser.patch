diff --git a/src/url-change.js b/src/url-change.js
--- a/src/url-change.js
+++ b/src/url-change.js
@@ -5,6 +5,10 @@
       const anchor = event.target.closest("a[href]");
       if (!anchor) return;
       const linkUrl = anchor.href;
+      // Only intercept external links - let Outlook's own SPA navigation work
+      if (new URL(linkUrl, window.location.href).origin === window.location.origin) return;
+      event.preventDefault();
+      event.stopPropagation();
       window.__TAURI__?.core
         ?.invoke("open_in_browser", { url: linkUrl })
         .then(() => console.log("URL successfully opened:", linkUrl))
